{
  "manifest_version": 3,
  "name": "Wootz Wallet",
  "version": "1.0",
  "description": "Wootzapp Wallet",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "wootz"
  ],
  "host_permissions": [],
  "background": {
    "service_worker": "Background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}